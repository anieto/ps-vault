---
interface Props {
  currentPath?: string;
}
const { currentPath = "/" } = Astro.props;
---

<header class="bg-navy-800 border-b border-navy-700">
  <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2.5 group">
      <img src="/logo.png" alt="P.S. Vault" class="h-8 w-8 rounded-md ring-1 ring-accent-600/60" />
      <span class="text-lg font-semibold text-white tracking-tight">P.S. Vault</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden sm:flex items-center gap-6">
      <a
        href="/docs"
        class:list={[
          "text-sm transition-colors",
          currentPath.startsWith("/docs")
            ? "text-white font-medium"
            : "text-navy-100 hover:text-white",
        ]}
      >
        Docs
      </a>
      <a
        href="/privacy"
        class:list={[
          "text-sm transition-colors",
          currentPath === "/privacy"
            ? "text-white font-medium"
            : "text-navy-100 hover:text-white",
        ]}
      >
        Privacy
      </a>
      <a
        href="/support"
        class:list={[
          "text-sm transition-colors",
          currentPath === "/support"
            ? "text-white font-medium"
            : "text-navy-100 hover:text-white",
        ]}
      >
        Support
      </a>
      <a
        href="https://github.com/anieto/ps-vault"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-navy-100 hover:text-white transition-colors"
      >
        GitHub
      </a>

      <button
        id="theme-toggle"
        aria-label="Toggle dark mode"
        class="h-8 w-8 flex items-center justify-center rounded-md text-navy-100 hover:text-white hover:bg-navy-700 transition-colors"
      >
        <svg id="icon-moon" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
        </svg>
        <svg id="icon-sun" class="h-4 w-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
        </svg>
      </button>
    </nav>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      aria-label="Open menu"
      class="sm:hidden h-9 w-9 flex items-center justify-center rounded-md text-navy-100 hover:text-white hover:bg-navy-700 transition-colors"
    >
      <svg id="icon-hamburger" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
      <svg id="icon-close" class="h-5 w-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile drawer -->
  <div
    id="mobile-menu"
    class="hidden sm:hidden border-t border-navy-700 bg-navy-800 px-6 py-4 flex flex-col gap-4"
  >
    <a
      href="/docs"
      class:list={[
        "text-sm transition-colors",
        currentPath.startsWith("/docs")
          ? "text-white font-medium"
          : "text-navy-100 hover:text-white",
      ]}
    >
      Docs
    </a>
    <a
      href="/privacy"
      class:list={[
        "text-sm transition-colors",
        currentPath === "/privacy"
          ? "text-white font-medium"
          : "text-navy-100 hover:text-white",
      ]}
    >
      Privacy
    </a>
    <a
      href="/support"
      class:list={[
        "text-sm transition-colors",
        currentPath === "/support"
          ? "text-white font-medium"
          : "text-navy-100 hover:text-white",
      ]}
    >
      Support
    </a>
    <a
      href="https://github.com/anieto/ps-vault"
      target="_blank"
      rel="noopener noreferrer"
      class="text-sm text-navy-100 hover:text-white transition-colors"
    >
      GitHub
    </a>
    <button
      id="theme-toggle-mobile"
      class="flex items-center gap-2 text-sm text-navy-100 hover:text-white transition-colors"
    >
      <svg id="icon-moon-mobile" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
      </svg>
      <svg id="icon-sun-mobile" class="h-4 w-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
      </svg>
      <span id="theme-label-mobile">Dark mode</span>
    </button>
  </div>
</header>

<script is:inline>
  function updateIcon() {
    var dark = document.documentElement.classList.contains('dark');
    document.getElementById('icon-moon').classList.toggle('hidden', dark);
    document.getElementById('icon-sun').classList.toggle('hidden', !dark);
    document.getElementById('icon-moon-mobile').classList.toggle('hidden', dark);
    document.getElementById('icon-sun-mobile').classList.toggle('hidden', !dark);
    document.getElementById('theme-label-mobile').textContent = dark ? 'Light mode' : 'Dark mode';
  }
  updateIcon();

  document.getElementById('theme-toggle').addEventListener('click', function() {
    var dark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', dark ? 'dark' : 'light');
    updateIcon();
  });

  document.getElementById('theme-toggle-mobile').addEventListener('click', function() {
    var dark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', dark ? 'dark' : 'light');
    updateIcon();
  });

  var menuOpen = false;
  document.getElementById('mobile-menu-btn').addEventListener('click', function() {
    menuOpen = !menuOpen;
    document.getElementById('mobile-menu').classList.toggle('hidden', !menuOpen);
    document.getElementById('icon-hamburger').classList.toggle('hidden', menuOpen);
    document.getElementById('icon-close').classList.toggle('hidden', !menuOpen);
  });
</script>
