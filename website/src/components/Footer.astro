---
const year = new Date().getFullYear();
---

<footer class="bg-navy-800 border-t border-navy-700 mt-auto">
  <div class="max-w-5xl mx-auto px-6 py-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="text-sm text-navy-100">
        &copy; {year} P.S. Vault &mdash; <a
          href="https://github.com/anieto/ps-vault/blob/main/LICENSE"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-white transition-colors">AGPLv3</a
        >
      </div>
      <nav class="flex items-center gap-5">
        <a
          href="/privacy"
          class="text-sm text-navy-100 hover:text-white transition-colors"
        >
          Privacy
        </a>
        <a
          href="/support"
          class="text-sm text-navy-100 hover:text-white transition-colors"
        >
          Support
        </a>
        <a
          href="https://github.com/anieto/ps-vault"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-navy-100 hover:text-white transition-colors"
        >
          GitHub
        </a>
        <a
          href="https://ko-fi.com/psvault"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-accent-500 hover:text-accent-600 transition-colors font-medium"
        >
          Support development
        </a>
      </nav>
    </div>
  </div>
</footer>
