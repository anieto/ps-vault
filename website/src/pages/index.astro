---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="P.S. Vault — Your final message, safely delivered.">
  <Header currentPath="/" />

  <main class="flex-1">
    <!-- Hero -->
    <section class="bg-navy-800 text-white">
      <div class="max-w-5xl mx-auto px-6 py-20 text-center">
        <img src="/logo.png" alt="P.S. Vault" class="h-32 w-32 rounded-2xl mx-auto mb-6 ring-2 ring-accent-600/60" />
        <h1 class="text-4xl sm:text-5xl font-semibold tracking-tight mb-4 leading-tight">
          Your final message,<br />safely delivered.
        </h1>
        <p class="text-lg text-navy-100 max-w-2xl mx-auto mb-8 leading-relaxed">
          P.S. Vault is a self-hostable dead man's switch. Store encrypted vaults containing
          passwords, accounts, and documents. If you stop checking in, your vaults are
          automatically delivered to the people you trust.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a
            href="/docs"
            class="inline-flex items-center justify-center px-6 py-3 rounded-lg bg-accent-600 hover:bg-accent-500 text-white font-medium transition-colors text-sm"
          >
            Get started
          </a>
          <a
            href="https://github.com/anieto/ps-vault"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-6 py-3 rounded-lg border border-navy-100/30 text-navy-100 hover:text-white hover:border-white/50 font-medium transition-colors text-sm"
          >
            View on GitHub
          </a>
        </div>
        <p class="mt-6 text-xs text-navy-100/60">
          Free and open source &mdash; AGPLv3
        </p>
      </div>
    </section>

    <!-- Disclaimer -->
    <div class="bg-amber-50 border-y border-amber-200">
      <div class="max-w-5xl mx-auto px-6 py-3 flex items-center justify-center gap-2">
        <svg class="h-4 w-4 text-amber-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <p class="text-sm text-amber-800">
          P.S. Vault is a personal tool for sharing information with loved ones. It is not a substitute for a legal will or estate plan.
        </p>
      </div>
    </div>

    <!-- Privacy First -->
    <section class="max-w-5xl mx-auto px-6 py-16">
      <div class="grid md:grid-cols-2 gap-10 items-center">
        <div>
          <span class="text-xs font-semibold text-accent-600 uppercase tracking-wider">Privacy first</span>
          <h2 class="text-2xl font-semibold text-text-primary mt-2 mb-4">
            Zero-knowledge encryption
          </h2>
          <p class="text-text-secondary leading-relaxed mb-4">
            Your vault contents are encrypted on your device before they ever leave it.
            The server stores only ciphertext. Even the person running the server cannot
            read your data.
          </p>
          <ul class="space-y-2">
            {[
              "No cloud accounts required — you host it yourself",
              "No telemetry, no analytics, no third-party services",
              "All encryption happens in your browser (WebCrypto API)",
              "Files encrypted client-side before upload",
              "The server never sees your password, your keys, or your vault contents",
            ].map((item) => (
              <li class="flex items-start gap-2 text-sm text-text-secondary">
                <span class="text-success-700 mt-0.5 font-bold flex-shrink-0">&#10003;</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-navy-800 rounded-lg p-6 font-mono text-sm text-navy-100 leading-relaxed">
          <p class="text-navy-100/50 text-xs mb-3">Key hierarchy</p>
          <p>Your Password</p>
          <p class="pl-4 text-navy-100/70">&rarr; Argon2id &rarr; Master Key</p>
          <p class="pl-8 text-navy-100/50 text-xs mt-1 mb-3">never leaves your device</p>
          <p>Per vault:</p>
          <p class="pl-4 text-navy-100/70">&rarr; Random Content Key (CEK)</p>
          <p class="pl-8 text-navy-100/70">&rarr; CEK encrypted with Master Key</p>
          <p class="pl-8 text-navy-100/70">&rarr; Entries encrypted with CEK</p>
          <p class="mt-3">Per beneficiary:</p>
          <p class="pl-4 text-navy-100/70">&rarr; Access Key from shared secret</p>
          <p class="pl-8 text-navy-100/70">&rarr; CEK encrypted with Access Key</p>
          <p class="pl-8 text-navy-100/50 text-xs mt-1">wrong secret = decryption fails</p>
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section class="bg-surface-muted border-y border-border">
      <div class="max-w-5xl mx-auto px-6 py-16">
        <h2 class="text-2xl font-semibold text-text-primary text-center mb-10">
          How it works
        </h2>
        <div class="grid sm:grid-cols-3 gap-6">
          {[
            {
              step: "1",
              title: "Create your vaults",
              body: "Store passwords, accounts, documents, and anything else your loved ones may need. Everything is encrypted before it leaves your device.",
            },
            {
              step: "2",
              title: "Check in regularly",
              body: "Set a check-in interval — daily, weekly, monthly, up to a year. You'll receive reminders. A simple click or login counts as a check-in.",
            },
            {
              step: "3",
              title: "Vaults are delivered",
              body: "If you stop checking in, your named beneficiaries receive a secure link to access only the vaults you assigned to them.",
            },
          ].map(({ step, title, body }) => (
            <div class="bg-surface rounded-lg border border-border p-6 shadow-card">
              <div class="h-8 w-8 rounded-full bg-primary-50 flex items-center justify-center mb-4">
                <span class="text-sm font-semibold text-primary-600">{step}</span>
              </div>
              <h3 class="font-semibold text-text-primary mb-2">{title}</h3>
              <p class="text-sm text-text-secondary leading-relaxed">{body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="max-w-5xl mx-auto px-6 py-16">
      <h2 class="text-2xl font-semibold text-text-primary text-center mb-10">Features</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          {
            title: "9 entry types",
            body: "Logins, secure notes, files, contacts, financial accounts, cards, identity documents, crypto wallets, and custom fields.",
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75a1.875 1.875 0 0 1 0 3.75H5.625a1.875 1.875 0 0 1 0-3.75Z" />`,
          },
          {
            title: "Escalating reminders",
            body: "Three levels of reminders before trigger, plus an abort window after trigger fires — giving you every chance to cancel.",
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0" />`,
          },
          {
            title: "TOTP multi-factor auth",
            body: "Works with Google Authenticator, Authy, 1Password, and any TOTP app. Eight single-use backup codes included.",
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />`,
          },
          {
            title: "Version history",
            body: "Every entry keeps its last 10 versions. View diffs and restore any version at any time.",
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />`,
          },
          {
            title: "Preview as beneficiary",
            body: "See exactly what your beneficiary will see before any trigger. Verify the experience is right.",
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />`,
          },
          {
            title: "Import from password managers",
            body: "Import from 1Password, Bitwarden, LastPass, KeePass, or any CSV. Processed entirely client-side.",
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />`,
          },
          {
            title: "Recovery key",
            body: "A 24-word BIP39 mnemonic lets you recover your vaults even if you forget your password.",
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 0 1 3 3m3 0a6 6 0 0 1-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 0 1 21.75 8.25Z" />`,
          },
          {
            title: "Admin panel",
            body: "User management, email queue, audit log, SMTP config, storage backends, branding, and invite codes.",
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M10.343 3.94c.09-.542.56-.94 1.11-.94h1.093c.55 0 1.02.398 1.11.94l.149.894c.07.424.384.764.78.93.398.164.855.142 1.205-.108l.737-.527a1.125 1.125 0 0 1 1.45.12l.773.774c.39.389.44 1.002.12 1.45l-.527.737c-.25.35-.272.806-.107 1.204.165.397.505.71.93.78l.893.15c.543.09.94.559.94 1.109v1.094c0 .55-.397 1.02-.94 1.11l-.894.149c-.424.07-.764.383-.929.78-.165.398-.143.854.107 1.204l.527.738c.32.447.269 1.06-.12 1.45l-.774.773a1.125 1.125 0 0 1-1.449.12l-.738-.527c-.35-.25-.806-.272-1.203-.107-.398.165-.71.505-.781.929l-.149.894c-.09.542-.56.94-1.11.94h-1.094c-.55 0-1.019-.398-1.11-.94l-.148-.894c-.071-.424-.384-.764-.781-.93-.398-.164-.854-.142-1.204.108l-.738.527c-.447.32-1.06.269-1.45-.12l-.773-.774a1.125 1.125 0 0 1-.12-1.45l.527-.737c.25-.35.272-.806.108-1.204-.165-.397-.506-.71-.93-.78l-.894-.15c-.542-.09-.94-.56-.94-1.109v-1.094c0-.55.398-1.02.94-1.11l.894-.149c.424-.07.765-.383.93-.78.165-.398.143-.854-.108-1.204l-.526-.738a1.125 1.125 0 0 1 .12-1.45l.773-.773a1.125 1.125 0 0 1 1.45-.12l.737.527c.35.25.807.272 1.204.107.397-.165.71-.505.78-.929l.15-.894Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />`,
          },
          {
            title: "S3-compatible storage",
            body: "Store encrypted files on local disk, AWS S3, Backblaze B2, Cloudflare R2, or MinIO.",
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 5.625c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" />`,
          },
        ].map(({ title, body, icon }) => (
          <div class="bg-surface rounded-lg border border-border p-5 shadow-card hover:shadow-card-hover transition-shadow">
            <div class="h-9 w-9 rounded-lg bg-navy-50 flex items-center justify-center mb-3">
              <svg class="h-5 w-5 text-navy-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" set:html={icon} />
            </div>
            <h3 class="font-semibold text-text-primary mb-1.5">{title}</h3>
            <p class="text-sm text-text-secondary leading-relaxed">{body}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Self-hosting CTA -->
    <section class="bg-navy-800 text-white">
      <div class="max-w-5xl mx-auto px-6 py-16 text-center">
        <h2 class="text-2xl font-semibold mb-3">Self-host in minutes</h2>
        <p class="text-navy-100 mb-6 max-w-xl mx-auto text-sm leading-relaxed">
          A single <code class="bg-navy-700 px-1.5 py-0.5 rounded text-xs">docker compose up</code> gets
          you running with PostgreSQL included. All configuration is via environment variables.
          Migrations run automatically on startup.
        </p>
        <a
          href="/docs"
          class="inline-flex items-center justify-center px-6 py-3 rounded-lg bg-accent-600 hover:bg-accent-500 text-white font-medium transition-colors text-sm"
        >
          Read the docs
        </a>
      </div>
    </section>

    <!-- Support -->
    <section class="max-w-5xl mx-auto px-6 py-12 text-center">
      <p class="text-text-secondary text-sm mb-4">
        P.S. Vault is free, open source software built and maintained by a single developer.
      </p>
      <a
        href="https://ko-fi.com/psvault"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center px-6 py-3 rounded-lg bg-accent-600 hover:bg-accent-500 text-white font-medium transition-colors text-sm"
      >
        Support development on Ko-fi
      </a>
    </section>
  </main>

  <Footer />
</Layout>
