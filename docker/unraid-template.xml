<?xml version="1.0"?>
<Container version="2">
  <Name>ps-vault</Name>
  <Repository>ghcr.io/ps-vault/ps-vault:latest</Repository>
  <Registry>https://github.com/ps-vault/ps-vault/pkgs/container/ps-vault</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support/>
  <Project/>
  <Overview>P.S. Vault — A self-hosted Emergency Release Switch for securely delivering encrypted vaults to your loved ones.</Overview>
  <Category>Tools: Productivity:</Category>
  <WebUI>http://[IP]:[PORT:3000]/</WebUI>
  <TemplateURL/>
  <Icon/>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Requires/>
  <Config Name="Web Port" Target="3000" Default="3000" Mode="tcp" Description="Web UI port" Type="Port" Display="always" Required="true" Mask="false">3000</Config>
  <Config Name="API Port" Target="8080" Default="8080" Mode="tcp" Description="API port (only expose if using a reverse proxy)" Type="Port" Display="advanced" Required="false" Mask="false">8080</Config>
  <Config Name="Data Path" Target="/data" Default="/mnt/user/appdata/ps-vault" Mode="rw" Description="Persistent data directory (database, files)" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/ps-vault</Config>
  <Config Name="PUID" Target="PUID" Default="99" Mode="" Description="User ID for file permissions" Type="Variable" Display="advanced" Required="false" Mask="false">99</Config>
  <Config Name="PGID" Target="PGID" Default="100" Mode="" Description="Group ID for file permissions" Type="Variable" Display="advanced" Required="false" Mask="false">100</Config>
  <Config Name="JWT Secret" Target="JWT_SECRET" Default="" Mode="" Description="Secret key for JWT signing — use a long random string" Type="Variable" Display="always" Required="true" Mask="true"/>
  <Config Name="Encryption Pepper" Target="ENCRYPTION_PEPPER" Default="" Mode="" Description="Server-side pepper for key verification — use a long random string" Type="Variable" Display="always" Required="true" Mask="true"/>
  <Config Name="Base URL" Target="BASE_URL" Default="http://localhost:3000" Mode="" Description="Publicly accessible URL for your P.S. Vault instance" Type="Variable" Display="always" Required="true" Mask="false">http://localhost:3000</Config>
  <Config Name="Database URL" Target="DATABASE_URL" Default="" Mode="" Description="PostgreSQL connection string. Leave blank to use the bundled SQLite database." Type="Variable" Display="advanced" Required="false" Mask="true"/>
  <Config Name="SMTP Host" Target="SMTP_HOST" Default="" Mode="" Description="SMTP server hostname for sending emails" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="SMTP Port" Target="SMTP_PORT" Default="587" Mode="" Description="SMTP server port" Type="Variable" Display="always" Required="true" Mask="false">587</Config>
  <Config Name="SMTP User" Target="SMTP_USER" Default="" Mode="" Description="SMTP username" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="SMTP Password" Target="SMTP_PASSWORD" Default="" Mode="" Description="SMTP password" Type="Variable" Display="always" Required="true" Mask="true"/>
  <Config Name="From Email" Target="SMTP_FROM" Default="" Mode="" Description="Sender email address (e.g. vault@yourdomain.com)" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="Registration Mode" Target="REGISTRATION_MODE" Default="invite" Mode="" Description="Who can register: open, invite, or closed" Type="Variable" Display="always" Required="false" Mask="false">invite</Config>
  <Config Name="Storage Backend" Target="STORAGE_BACKEND" Default="local" Mode="" Description="File storage backend: local, s3, gdrive, onedrive" Type="Variable" Display="advanced" Required="false" Mask="false">local</Config>
  <Config Name="Timezone" Target="TZ" Default="UTC" Mode="" Description="Container timezone" Type="Variable" Display="advanced" Required="false" Mask="false">UTC</Config>
</Container>
