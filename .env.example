# ============================================================
# P.S. Vault — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit your .env file to version control.
# ============================================================

# ------------------------------------------------------------
# Core
# ------------------------------------------------------------

# The public URL where P.S. Vault is accessible (no trailing slash)
PSVAULT_BASE_URL=https://vault.yourdomain.com

# Secret key for signing JWT tokens — generate with: openssl rand -hex 32
PSVAULT_JWT_SECRET=change_me_generate_with_openssl_rand_hex_32

# Server-side pepper added to all key derivation — generate with: openssl rand -hex 32
PSVAULT_ENCRYPTION_PEPPER=change_me_generate_with_openssl_rand_hex_32

# Application environment: development | production
PSVAULT_ENV=production

# API server port (internal, behind reverse proxy)
PSVAULT_API_PORT=8080

# Web server port (internal, behind reverse proxy)
PSVAULT_WEB_PORT=3000

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------

# Full PostgreSQL connection string
PSVAULT_DB_URL=postgres://psvault:psvault@db:5432/psvault?sslmode=disable

# Database type: postgres | sqlite
PSVAULT_DB_TYPE=postgres

# PostgreSQL container settings (used by the bundled db container)
POSTGRES_DB=psvault
POSTGRES_USER=psvault
POSTGRES_PASSWORD=change_me_strong_password

# SQLite path (only used if PSVAULT_DB_TYPE=sqlite)
# PSVAULT_SQLITE_PATH=/config/psvault.db

# ------------------------------------------------------------
# File Storage
# ------------------------------------------------------------

# Storage backend: local | s3 | gdrive | onedrive
PSVAULT_STORAGE_BACKEND=local

# Local storage path (used when backend=local)
PSVAULT_STORAGE_LOCAL_PATH=/data/files

# S3-compatible settings (used when backend=s3)
# PSVAULT_S3_ENDPOINT=https://s3.amazonaws.com
# PSVAULT_S3_BUCKET=my-psvault-bucket
# PSVAULT_S3_REGION=us-east-1
# PSVAULT_S3_ACCESS_KEY=
# PSVAULT_S3_SECRET_KEY=

# Google Drive settings (used when backend=gdrive)
# PSVAULT_GDRIVE_CLIENT_ID=
# PSVAULT_GDRIVE_CLIENT_SECRET=

# OneDrive settings (used when backend=onedrive)
# PSVAULT_ONEDRIVE_CLIENT_ID=
# PSVAULT_ONEDRIVE_CLIENT_SECRET=
# PSVAULT_ONEDRIVE_TENANT_ID=

# Max file size per upload in MB
PSVAULT_MAX_FILE_SIZE_MB=100

# ------------------------------------------------------------
# Email (SMTP) — Required
# ------------------------------------------------------------

PSVAULT_SMTP_HOST=smtp.yourmailprovider.com
PSVAULT_SMTP_PORT=587
PSVAULT_SMTP_USER=your@email.com
PSVAULT_SMTP_PASS=your_smtp_password
# TLS mode: none | starttls | tls
PSVAULT_SMTP_TLS=starttls
PSVAULT_SMTP_FROM=noreply@yourdomain.com
PSVAULT_SMTP_FROM_NAME=P.S. Vault

# ------------------------------------------------------------
# SMS (Optional)
# ------------------------------------------------------------

# SMS provider: twilio | vonage | sns | (leave empty to disable)
PSVAULT_SMS_PROVIDER=

# Twilio
# PSVAULT_TWILIO_ACCOUNT_SID=
# PSVAULT_TWILIO_AUTH_TOKEN=
# PSVAULT_TWILIO_FROM_NUMBER=

# Vonage
# PSVAULT_VONAGE_API_KEY=
# PSVAULT_VONAGE_API_SECRET=
# PSVAULT_VONAGE_FROM_NUMBER=

# ------------------------------------------------------------
# Server Health Alerts
# ------------------------------------------------------------

# Personal email to receive out-of-band server health alerts
# (use a personal email outside this system, e.g. Gmail)
PSVAULT_SERVER_HEALTH_EMAIL=your.personal@gmail.com

# Alert if server is unreachable for this many hours
PSVAULT_SERVER_HEALTH_ALERT_HOURS=4

# ------------------------------------------------------------
# Registration & Users
# ------------------------------------------------------------

# Registration mode: open | invite | closed
PSVAULT_REGISTRATION_MODE=invite

# Email of the first admin user (auto-promoted on first registration)
PSVAULT_ADMIN_EMAIL=your@email.com

# ------------------------------------------------------------
# File Permissions (Unraid / Linux)
# ------------------------------------------------------------

# User ID for file ownership (Unraid default: 99)
PUID=99

# Group ID for file ownership (Unraid default: 100)
PGID=100

# ------------------------------------------------------------
# Branding (Optional — for self-hosters who want to rebrand)
# ------------------------------------------------------------

PSVAULT_APP_NAME=P.S. Vault
# PSVAULT_APP_LOGO_URL=
